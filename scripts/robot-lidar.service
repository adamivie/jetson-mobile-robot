[Unit]
Description=Robot YDLidar 4ROS Scanner
After=robot-foxglove.service
Wants=robot-foxglove.service

[Service]
Type=simple
ExecStart=/bin/bash -c '\
  source /opt/ros/humble/setup.bash && \
  source /home/slurd/ros2_ws/install/setup.bash && \
  export RMW_IMPLEMENTATION=rmw_cyclonedds_cpp && \
  exec ros2 launch robot_vision lidar.launch.py'
Restart=on-failure
RestartSec=5
StandardOutput=journal
StandardError=journal
SyslogIdentifier=robot-lidar

[Install]
WantedBy=default.target
