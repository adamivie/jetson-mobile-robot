[Unit]
Description=MAVROS ArduRover Bridge
After=robot-foxglove.service
Wants=robot-foxglove.service

[Service]
ExecStart=/bin/bash -c 'source /opt/ros/humble/setup.bash && source /home/slurd/ros2_ws/install/setup.bash && export RMW_IMPLEMENTATION=rmw_cyclonedds_cpp && exec ros2 launch robot_vision mavros.launch.py'
Restart=on-failure
RestartSec=5
Environment=HOME=/home/slurd

[Install]
WantedBy=default.target
